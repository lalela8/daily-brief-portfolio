{
  "$schema": "https://busibox.io/schemas/app-manifest-v1.json",
  "name": "Daily Portfolio Briefing",
  "id": "daily-portfolio-briefing",
  "version": "1.0.0",
  "description": "A simple daily portfolio briefing application.",
  "icon": "Checklist",
  "defaultPath": "/myapp",
  "defaultPort": 4923,
  "healthEndpoint": "/api/health",
  "buildCommand": "npm run build",
  "startCommand": "npm start",
  "appMode": "frontend",
  "requiredEnvVars": [],
  "optionalEnvVars": [
    "NEXT_PUBLIC_DEBUG",
    "DEMO_AGENT_API_URL"
  ],
  "busiboxAppVersion": "^3.0.0"
}
